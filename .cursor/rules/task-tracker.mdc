### User Reducer

File: `context/user/userReducer.ts`

```ts
import { User } from '@/types/user';
import { SET_USER, CLEAR_USER, SET_LOADING, UNSET_LOADING } from '@/helpers/types';

interface State {
  user: User | null;
  loading: boolean;
}

export default function UserReducer(state: State, action: any): State {
  switch (action.type) {
    case SET_LOADING:
      return { ...state, loading: true };
    case UNSET_LOADING:
      return { ...state, loading: false };
    case SET_USER:
      return { ...state, user: action.payload };
    case CLEAR_USER:
      return { ...state, user: null };
    default:
      return state;
  }
}
```

### UserState Provider

File: `context/user/UserState.tsx`

Auth is local/mock — no backend. Credentials are not validated against a server. login() and signup() store the user in AsyncStorage so the session persists across restarts.

```tsx
import React, { useMemo, useReducer, useEffect } from 'react';
import AsyncStorage from '@react-native-async-storage/async-storage';
import UserContext from './userContext';
import UserReducer from './userReducer';
import { SET_USER, CLEAR_USER, SET_LOADING, UNSET_LOADING } from '@/helpers/types';
import { User } from '@/types/user';

const AUTH_KEY = 'AUTH_USER';

const UserState = (props: any) => {
  const initialState = {
    user: null,
    loading: false,
  };

  const [state, dispatch] = useReducer(UserReducer, initialState);

  useEffect(() => {
    restoreSession();
  }, []);

  const restoreSession = async () => {
    dispatch({ type: SET_LOADING });
    try {
      const raw = await AsyncStorage.getItem(AUTH_KEY);
      if (raw) dispatch({ type: SET_USER, payload: JSON.parse(raw) });
    } catch {}
    dispatch({ type: UNSET_LOADING });
  };

  const login = async (email: string, password: string) => {
    dispatch({ type: SET_LOADING });
    // mock — swap for real API call when backend is ready
    const user: User = { id: Date.now().toString(), name: email.split('@')[0], email };
    await AsyncStorage.setItem(AUTH_KEY, JSON.stringify(user));
    dispatch({ type: SET_USER, payload: user });
    dispatch({ type: UNSET_LOADING });
  };

  const signup = async (name: string, email: string, _password: string) => {
    dispatch({ type: SET_LOADING });
    const user: User = { id: Date.now().toString(), name, email };
    await AsyncStorage.setItem(AUTH_KEY, JSON.stringify(user));
    dispatch({ type: SET_USER, payload: user });
    dispatch({ type: UNSET_LOADING });
  };

  const logout = async () => {
    await AsyncStorage.removeItem(AUTH_KEY);
    dispatch({ type: CLEAR_USER });
  };

  const setUser = (user: User) => {
    dispatch({ type: SET_USER, payload: user });
  };

  const clearUser = () => {
    dispatch({ type: CLEAR_USER });
  };

  const contextValues = useMemo(
    () => ({
      user: state.user,
      loading: state.loading,
      login,
      signup,
      logout,
      setUser,
      clearUser,
    }),
    [state.user, state.loading],
  );

  return (
    <UserContext.Provider value={contextValues}>
      {props.children}
    </UserContext.Provider>
  );
};

export default UserState;
```

