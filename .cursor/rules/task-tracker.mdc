## State Management Pattern

`TaskState` must:
1. Accept a `userId` prop so tasks are stored per-user (two users on the same device must not share tasks)
2. Call `loadTasksFromStorage` automatically in a `useEffect` when `userId` is available
3. Compute `filteredTasks` from `tasks` + `filter` and expose it on context — screens never filter manually

```tsx
import React, { useMemo, useReducer, useEffect } from 'react';
import TaskContext from './taskContext';
import TaskReducer from './taskReducer';
import { ADD_TASK, TOGGLE_TASK, SET_FILTER, SET_LOADING, SET_TASKS, UNSET_LOADING } from '@/helpers/types';
import { loadTasks, saveTasks } from '@/storage/task-storage';
import { Task, TaskFilter } from '@/types/task';

interface Props {
  userId: string;
  children: React.ReactNode;
}

const TaskState = ({ userId, children }: Props) => {
  const initialState = {
    tasks: [] as Task[],
    filter: 'all' as TaskFilter,
    loading: false,
  };

  const [state, dispatch] = useReducer(TaskReducer, initialState);

  useEffect(() => {
    if (userId) loadTasksFromStorage();
  }, [userId]);

  const loadTasksFromStorage = async () => {
    dispatch({ type: SET_LOADING });
    const tasks = await loadTasks(userId);
    dispatch({ type: SET_TASKS, payload: tasks });
    dispatch({ type: UNSET_LOADING });
  };

  const addTask = async (title: string, category?: string) => {
    const trimmed = title.trim();
    if (!trimmed) return;
    const newTask: Task = {
      id: Date.now().toString(),
      title: trimmed,
      completed: false,
      createdAt: Date.now(),
      category,
    };
    const updated = [newTask, ...state.tasks];
    dispatch({ type: ADD_TASK, payload: newTask });
    await saveTasks(userId, updated);
  };

  const toggleTask = async (id: string) => {
    const updated = state.tasks.map((t) =>
      t.id === id ? { ...t, completed: !t.completed } : t,
    );
    dispatch({ type: TOGGLE_TASK, payload: id });
    await saveTasks(userId, updated);
  };

  const setFilter = (filter: TaskFilter) => {
    dispatch({ type: SET_FILTER, payload: filter });
  };

  const filteredTasks = useMemo(() => {
    if (state.filter === 'active') return state.tasks.filter((t) => !t.completed);
    if (state.filter === 'completed') return state.tasks.filter((t) => t.completed);
    return state.tasks;
  }, [state.tasks, state.filter]);

  const contextValues = useMemo(
    () => ({
      tasks: state.tasks,
      filteredTasks,
      filter: state.filter,
      loading: state.loading,
      addTask,
      toggleTask,
      setFilter,
    }),
    [state.tasks, filteredTasks, state.filter, state.loading],
  );

  return (
    <TaskContext.Provider value={contextValues}>
      {children}
    </TaskContext.Provider>
  );
};

export default TaskState;
```

Rules:
- Always wrap contextValues in useMemo
- Always list all state values in the useMemo dependency array
- Never put business logic inside UI components
- All async operations go through context action functions
- Screens always consume `filteredTasks` — never filter `tasks` manually in a component

