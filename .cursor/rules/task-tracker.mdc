import TaskContext from '@/context/task/taskContext';

export function useTasksContext() {
  return useContext(TaskContext);
}
```

`use-onboarding.ts`:

```ts
import { useState, useEffect } from 'react';
import AsyncStorage from '@react-native-async-storage/async-storage';
import { router } from 'expo-router';

const ONBOARDING_KEY = 'HAS_SEEN_WALKTHROUGH';

export function useOnboarding() {
  const [hasSeenWalkthrough, setHasSeenWalkthrough] = useState(false);
  const [isLoading, setIsLoading] = useState(true);

  useEffect(() => {
    AsyncStorage.getItem(ONBOARDING_KEY)
      .then((value) => setHasSeenWalkthrough(value === 'true'))
      .finally(() => setIsLoading(false));
  }, []);

  const markSeen = async () => {
    await AsyncStorage.setItem(ONBOARDING_KEY, 'true');
    setHasSeenWalkthrough(true);
    router.replace('/(auth)/login');
  };

  return { hasSeenWalkthrough, isLoading, markSeen };
}
```

### `api/hooks/` — data-fetching hooks co-located with services

```
api/hooks/
├── index.ts
└── tasks/
    ├── index.ts
    ├── use-tasks.ts
    ├── use-add-task.ts
    └── use-toggle-task.ts
```

These hooks call `api/services/tasks.service.ts`, which in development reads from `_data/tasks.ts`.

