SplashScreen.preventAutoHideAsync();

export default function RootLayout() {
  // hide splash once UserState has finished restoreSession
  // pass an onReady callback from UserState or check loading === false
  useEffect(() => {
    SplashScreen.hideAsync();
  }, []);

  // ...providers + Stack
}
```

