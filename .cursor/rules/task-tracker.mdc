## Routing (expo-router)

`app/_layout.tsx` — root layout, wraps everything in providers:

```tsx
import '../global.css';
import { Stack } from 'expo-router';
import { SafeAreaProvider } from 'react-native-safe-area-context';
import TaskState from '@/context/task/TaskState';
import UserState from '@/context/user/UserState';

export default function RootLayout() {
  return (
    <SafeAreaProvider>
      <UserState>
        <AuthenticatedTaskState>
          <Stack screenOptions={{ headerShown: false }} />
        </AuthenticatedTaskState>
      </UserState>
    </SafeAreaProvider>
  );
}

function AuthenticatedTaskState({ children }: { children: React.ReactNode }) {
  const { user } = useUserContext();
  if (!user) return <>{children}</>;
  return <TaskState userId={user.id}>{children}</TaskState>;
}
```

`AuthenticatedTaskState` is a small wrapper that only mounts `TaskState` when a user is present. This ensures tasks are always scoped to the logged-in user's id. If no user is logged in, the task context is simply not mounted (the auth screens don't need it).

`app/index.tsx` — redirect based on both onboarding state and auth state. Must wait for both to be ready before redirecting, otherwise the splash → login flash occurs even when a session exists.

```tsx
import { Redirect } from 'expo-router';
import { View, ActivityIndicator } from 'react-native';
import { useOnboarding } from '@/hooks/use-onboarding';
import { useUserContext } from '@/hooks/use-user-context';

export default function Index() {
  const { hasSeenWalkthrough, isLoading: onboardingLoading } = useOnboarding();
  const { user, loading: userLoading } = useUserContext();

  if (onboardingLoading || userLoading) {
    return (
      <View className="flex-1 items-center justify-center bg-cream">
        <ActivityIndicator />
      </View>
    );
  }

  if (!hasSeenWalkthrough) return <Redirect href="/(onboarding)/walkthrough" />;
  if (!user) return <Redirect href="/(auth)/login" />;
  return <Redirect href="/(tabs)" />;
}
```

Route files in `app/` import screens:

```tsx
// app/(tabs)/index.tsx
import HomeScreen from '@/screens/home-screen';
export default HomeScreen;
```

